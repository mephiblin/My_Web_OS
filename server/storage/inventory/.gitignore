# Ignore runtime-installed packages and mutable inventory state by default.
*
!*/
!.gitignore
!.gitkeep

# Canonical built-in app registry required for tests/bootstrap.
!system/
system/*
!system/apps.json

# Package fixtures required for tests and package-first built-in replacement.
!apps/hello-sandbox/
!apps/hello-sandbox/**
!apps/doc-viewer/
!apps/doc-viewer/**
!apps/editor/
!apps/editor/**
!apps/model-viewer/
!apps/model-viewer/**
!apps/calendar-addon/
!apps/calendar-addon/**
