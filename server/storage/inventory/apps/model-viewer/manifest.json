{
  "id": "model-viewer",
  "title": "모델 뷰어",
  "description": "GLTF/GLB/FBX/OBJ 3D 모델 미리보기 애드온",
  "version": "1.0.0",
  "type": "app",
  "singleton": true,
  "runtime": {
    "type": "sandbox-html",
    "entry": "index.html"
  },
  "permissions": [
    "host.file.read"
  ],
  "capabilities": [
    "file.preview",
    "model.inspect",
    "model.screenshot"
  ],
  "fileAssociations": [
    {
      "extensions": [
        "gltf",
        "glb",
        "fbx",
        "obj"
      ],
      "actions": [
        "preview",
        "open"
      ],
      "defaultAction": "open"
    }
  ],
  "window": {
    "width": 1100,
    "height": 760,
    "minWidth": 640,
    "minHeight": 420
  },
  "migration": {
    "currentSource": "client/src/apps/addons/model-viewer",
    "currentRuntime": "builtin-component-dev",
    "targetRuntime": "sandbox-html",
    "status": "sandbox-package-entry"
  },
  "contributes": {
    "fileContextMenu": [
      {
        "label": "모델 뷰어로 열기",
        "action": "open",
        "extensions": [
          "gltf",
          "glb",
          "fbx",
          "obj"
        ]
      }
    ],
    "fileCreateTemplates": [],
    "previewProviders": [
      {
        "label": "3D 모델 미리보기",
        "extensions": [
          "gltf",
          "glb",
          "fbx",
          "obj"
        ]
      }
    ],
    "thumbnailProviders": [
      {
        "label": "3D 모델 썸네일",
        "extensions": [
          "gltf",
          "glb",
          "fbx",
          "obj"
        ]
      }
    ],
    "settingsPanels": [],
    "backgroundServices": []
  }
}
