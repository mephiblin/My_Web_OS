{
  "id": "calendar-addon",
  "title": "Calendar Addon",
  "description": "Package Center calendar addon using the v2 source/provider calendar API.",
  "version": "1.1.0",
  "appModel": "package",
  "icon": "CalendarDays",
  "type": "app",
  "entry": "index.html",
  "singleton": true,
  "runtime": {
    "type": "sandbox-html",
    "entry": "index.html"
  },
  "permissions": [
    "app.data.list",
    "app.data.read",
    "app.data.write",
    "calendar.read",
    "calendar.write",
    "ui.notification",
    "window.open"
  ],
  "window": {
    "width": 960,
    "height": 760,
    "minWidth": 640,
    "minHeight": 420
  },
  "contributes": {
    "widgets": [
      {
        "id": "calendar-widget",
        "label": "Calendar Widget",
        "entry": "widget.html",
        "defaultSize": {
          "w": 360,
          "h": 260
        },
        "minSize": {
          "w": 260,
          "h": 190
        }
      }
    ]
  }
}
