{
  "id": "editor",
  "title": "코드 에디터",
  "description": "호스트/패키지 파일 편집 애드온",
  "version": "1.0.0",
  "type": "app",
  "runtime": {
    "type": "sandbox-html",
    "entry": "index.html"
  },
  "permissions": [
    "host.file.read",
    "host.file.write"
  ],
  "capabilities": [
    "file.edit",
    "package.file.edit"
  ],
  "fileAssociations": [
    {
      "extensions": [
        "txt",
        "md",
        "markdown",
        "json",
        "js",
        "ts",
        "css",
        "html",
        "xml",
        "yml",
        "yaml",
        "csv",
        "log",
        "svelte",
        "sh",
        "py"
      ],
      "actions": [
        "open",
        "edit"
      ],
      "defaultAction": "edit"
    }
  ],
  "window": {
    "width": 1100,
    "height": 760,
    "minWidth": 640,
    "minHeight": 420
  },
  "migration": {
    "currentSource": "client/src/apps/addons/code-editor",
    "currentRuntime": "builtin-component-dev",
    "targetRuntime": "sandbox-html",
    "status": "sandbox-package-entry"
  },
  "contributes": {
    "fileContextMenu": [
      {
        "label": "코드 에디터로 편집",
        "action": "edit",
        "extensions": [
          "txt",
          "md",
          "markdown",
          "json",
          "js",
          "ts",
          "css",
          "html",
          "xml",
          "yml",
          "yaml",
          "csv",
          "log",
          "svelte",
          "sh",
          "py"
        ]
      }
    ],
    "fileCreateTemplates": [
      {
        "label": "텍스트 파일",
        "name": "제목없음.txt",
        "extension": "txt",
        "content": "",
        "action": "edit",
        "openAfterCreate": true
      },
      {
        "label": "마크다운 파일",
        "name": "제목없음.md",
        "extension": "md",
        "content": "# 제목없음\n\n",
        "action": "edit",
        "openAfterCreate": true
      },
      {
        "label": "JSON 파일",
        "name": "제목없음.json",
        "extension": "json",
        "content": "{\n  \n}\n",
        "action": "edit",
        "openAfterCreate": true
      }
    ],
    "previewProviders": [],
    "thumbnailProviders": [],
    "settingsPanels": [],
    "backgroundServices": []
  }
}
