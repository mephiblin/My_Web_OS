{
  "name": "web_os",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:server",
    "test:server": "node --test --test-concurrency=1 server/tests",
    "verify:syntax": "node tools/verify-syntax.js",
    "verify:packages": "npm run apps:registry:migrate -- --dry-run --fail-on-removal && npm run package:doctor -- --builtin-registry=server/storage/inventory/system/apps.json",
    "verify:client": "npm --prefix client run build",
    "verify:docker-config": "docker compose config",
    "verify": "npm run verify:syntax && npm test && npm run verify:packages && npm run verify:client",
    "verify:ci": "npm run verify:syntax && npm test && npm run verify:packages && npm run verify:client",
    "apps:registry:migrate": "node tools/migrate-apps-registry.js",
    "package:doctor": "node tools/package-doctor.js",
    "package:doctor:json": "node tools/package-doctor.js --json",
    "hardening:env": "node tools/generate-hardened-env.js --output=.env.hardened",
    "hardening:acme:config": "docker compose --env-file .env.hardened -f docker-compose.hardened.yml -f docker-compose.hardened-acme.yml config",
    "hardening:acme:up": "docker compose --env-file .env.hardened -f docker-compose.hardened.yml -f docker-compose.hardened-acme.yml up -d --build",
    "rehearsal:backup-restore": "bash tools/rehearse-storage-backup-restore.sh",
    "rehearsal:station-snapshot": "node tools/station-real-use-snapshot.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-svelte": "^1.0.1",
    "multer": "^2.1.1",
    "node-pty": "^1.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "svelte-chartjs": "^4.0.1",
    "systeminformation": "^5.31.5",
    "uuid": "^13.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
