{
  "id": "doc-viewer",
  "title": "문서 뷰어",
  "description": "문서/텍스트 미리보기 애드온",
  "version": "1.0.0",
  "type": "app",
  "runtime": {
    "type": "sandbox-html",
    "entry": "index.html"
  },
  "permissions": [
    "host.file.read"
  ],
  "capabilities": [
    "file.preview",
    "document.search"
  ],
  "fileAssociations": [
    {
      "extensions": [
        "pdf",
        "txt",
        "md",
        "markdown",
        "json",
        "csv",
        "log"
      ],
      "actions": [
        "preview",
        "open"
      ],
      "defaultAction": "open"
    }
  ],
  "window": {
    "width": 1100,
    "height": 760,
    "minWidth": 640,
    "minHeight": 420
  },
  "migration": {
    "currentSource": "client/src/apps/addons/document-viewer",
    "currentRuntime": "builtin-component-dev",
    "targetRuntime": "sandbox-html",
    "status": "sandbox-package-entry"
  },
  "contributes": {
    "fileContextMenu": [
      {
        "label": "문서 뷰어로 열기",
        "action": "open",
        "extensions": [
          "pdf",
          "txt",
          "md",
          "markdown",
          "json",
          "csv",
          "log"
        ]
      }
    ],
    "fileCreateTemplates": [],
    "previewProviders": [
      {
        "label": "문서 미리보기",
        "extensions": [
          "pdf",
          "txt",
          "md",
          "markdown",
          "json",
          "csv",
          "log"
        ]
      }
    ],
    "thumbnailProviders": [],
    "settingsPanels": [],
    "backgroundServices": []
  }
}
